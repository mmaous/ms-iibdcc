<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:gravity="bottom"
    tools:context=".PortraitActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:gravity="right"
            android:text="0"
            android:textAppearance="@style/TextAppearance.AppCompat.Display3"
            android:textColor="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp">

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_light"
                android:gravity="center"
                android:onClick="onClearClick"
                android:text="AC"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_light"
                android:gravity="center"
                android:onClick="onChangeSign"
                android:text="+/-"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_light"
                android:gravity="center"
                android:onClick="onPercentageClick"
                android:text="%"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_orange"
                android:gravity="center"
                android:onClick="onOperatorClick"
                android:text="/"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:onClick="onNumberClick"
                android:text="7"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="8"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="9"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_orange"
                android:gravity="center"
                android:text="x"
                android:onClick="onOperatorClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="4"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="5"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="6"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_orange"
                android:gravity="center"
                android:text="-"
                android:onClick="onOperatorClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="1"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="2"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="3"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_orange"
                android:gravity="center"
                android:text="+"
                android:onClick="onOperatorClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">


            <TextView
                android:layout_width="0dp"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:layout_weight="1"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="0"
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_gray_dark"
                android:gravity="center"
                android:text="."
                android:onClick="onNumberClick"
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="@dimen/circle_dim"
                android:layout_height="@dimen/circle_dim"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/circle_orange"
                android:gravity="center"
                android:onClick="onEqualsClick"
                android:text="="
                android:textAppearance="@style/TextAppearance.AppCompat.Large"
                android:textColor="@color/white" />


        </LinearLayout>
    </LinearLayout>


</RelativeLayout>